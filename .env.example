# =============================================================================
# Avantika Global Language AI — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# App
ENV=development
SECRET_KEY=generate-a-long-random-string-here

# Internal service auth
AGENT_SERVICE_INTERNAL_KEY=change-this-internal-key

# OpenAI (if not using shared AI platform)
OPENAI_API_KEY=sk-...

# Serper (web search for agents)
SERPER_API_KEY=...

# Shared AI Platform (optional — reduces cost)
AI_PLATFORM_URL=https://your-shared-platform.example.com
AI_PLATFORM_APP_KEY=your-app-key-here

# Model routing
CHEAP_MODEL=gpt-4o-mini
PREMIUM_MODEL=gpt-4o
USE_LOCAL_MODEL=false
LOCAL_MODEL=ollama/llama3

# Razorpay
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# Database (Docker defaults — change for production)
DATABASE_URL=postgresql+asyncpg://avantika:avantika@localhost:5432/avantika

# Redis (Docker defaults)
REDIS_URL=redis://localhost:6379/0

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...
